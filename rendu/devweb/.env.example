# Configuration du serveur d'inférence Ollama (équipe INFRA)
# Copiez ce fichier en .env et adaptez les valeurs si besoin :
#   cp .env.example .env

# URL du serveur Ollama exposé par l'INFRA
OLLAMA_URL=https://spooky-tableful-labored.ngrok-free.dev

# Nom du modèle à interroger (à mettre à jour quand le modèle financier sera déployé)
OLLAMA_MODEL=phi3.5
