   "source": [
    "# Fine-tuning modèle médical — TechCorp Hackathon\n",
    "**Groupe 23 — DATA/IA**\n",
    "\n",
    "Ce notebook fine-tune le modèle `Phi-3-mini-4k-instruct` sur un dataset de conversations médicales.\n",
    "\n",
    "**Avant de lancer :**\n",
    "1. Aller dans `Exécution` > `Modifier le type d'exécution`\n",
    "2. Choisir **GPU T4** comme accélérateur matériel\n",
    "3. Ensuite cliquer sur `Exécution` > `Tout exécuter`"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Vérification du GPU disponible\n",
    "import subprocess\n",
    "result = subprocess.run(['nvidia-smi'], capture_output=True, text=True)\n",
    "print(result.stdout if result.returncode == 0 else 'Pas de GPU détecté — vérifier les paramètres Colab')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Installation des dépendances\n",
    "!pip install -q transformers==4.45.0 peft==0.12.0 accelerate==0.34.0 bitsandbytes==0.43.0 datasets==2.20.0 trl==0.11.0"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "import torch\n",
    "import json\n",
    "from datasets import load_dataset, Dataset\n",
    "from transformers import (\n",
    "    AutoTokenizer, AutoModelForCausalLM,\n",
    "    TrainingArguments, BitsAndBytesConfig\n",
    ")\n",
    "from peft import LoraConfig, get_peft_model, TaskType, prepare_model_for_kbit_training\n",
    "from trl import SFTTrainer\n",
    "\n",
    "print('GPU disponible :', torch.cuda.is_available())\n",
    "if torch.cuda.is_available():\n",
    "    print('GPU :', torch.cuda.get_device_name(0))\n",
    "    print('VRAM :', round(torch.cuda.get_device_properties(0).total_memory / 1e9, 1), 'GB')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Chargement et nettoyage du dataset médical"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "print('Chargement du dataset médical depuis HuggingFace...')\n",
    "raw_dataset = load_dataset('ruslanmv/ai-medical-chatbot', split='train')\n",
    "print(f'Dataset brut : {len(raw_dataset)} exemples')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Nettoyage du dataset (même logique que notre script local)\n",
    "def clean_and_format(examples):\n",
    "    cleaned = []\n",
    "    seen = set()\n",
    "\n",
    "    for i in range(len(examples['Patient'])):\n",
    "        patient = examples['Patient'][i] or ''\n",
    "        doctor  = examples['Doctor'][i] or ''\n",
    "\n",
    "        # Supprimer les réponses tronquées\n",
    "        if doctor.strip().endswith('-->'):\n",
    "            continue\n",
    "        # Supprimer les champs vides ou trop courts\n",
    "        if len(patient.strip()) < 10 or len(doctor.strip()) < 10:\n",
    "            continue\n",
    "        # Supprimer les doublons\n",
    "        key = (patient[:80], doctor[:80])\n",
    "        if key in seen:\n",
    "            continue\n",
    "        seen.add(key)\n",
    "\n",
    "        # Formater en format Phi-3\n",
    "        text = f\"<|user|>\\n{patient.strip()}<|end|>\\n<|assistant|>\\n{doctor.strip()}<|end|>\"\n",
    "        cleaned.append({'text': text})\n",
    "\n",
    "    return cleaned\n",
    "\n",
    "print('Nettoyage en cours...')\n",
    "raw_dict = raw_dataset.to_dict()\n",
    "cleaned_data = clean_and_format(raw_dict)\n",
    "dataset = Dataset.from_list(cleaned_data)\n",
    "\n",
    "print(f'Après nettoyage : {len(dataset)} exemples')\n",
    "print(f'Exemple :\\n{dataset[0][\"text\"][:300]}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# On garde 20 000 exemples pour que l'entraînement reste rapide sur Colab\n",
    "import random\n",
    "random.seed(42)\n",
    "dataset = dataset.shuffle(seed=42).select(range(min(20000, len(dataset))))\n",
    "print(f'Dataset final pour entraînement : {len(dataset)} exemples')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Chargement du modèle avec quantization 4-bit"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "MODEL_NAME = 'microsoft/Phi-3-mini-4k-instruct'\n",
    "\n",
    "# Quantization 4-bit pour tenir dans la VRAM du GPU Colab\n",
    "bnb_config = BitsAndBytesConfig(\n",
    "    load_in_4bit=True,\n",
    "    bnb_4bit_compute_dtype=torch.float16,\n",
    "    bnb_4bit_use_double_quant=True,\n",
    "    bnb_4bit_quant_type='nf4'\n",
    ")\n",
    "\n",
    "print('Chargement du tokenizer...')\n",
    "tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME, trust_remote_code=True)\n",
    "if tokenizer.pad_token is None:\n",
    "    tokenizer.pad_token = tokenizer.eos_token\n",
    "tokenizer.padding_side = 'right'\n",
    "\n",
    "print('Chargement du modèle (peut prendre 2-3 minutes)...')\n",
    "model = AutoModelForCausalLM.from_pretrained(\n",
    "    MODEL_NAME,\n",
    "    quantization_config=bnb_config,\n",
    "    device_map='auto',\n",
    "    torch_dtype=torch.float16,\n",
    "    trust_remote_code=True\n",
    ")\n",
    "model = prepare_model_for_kbit_training(model)\n",
    "print('Modèle chargé !')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Configuration LoRA"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "lora_config = LoraConfig(\n",
    "    r=16,\n",
    "    lora_alpha=32,\n",
    "    target_modules=['qkv_proj', 'o_proj', 'gate_proj', 'up_proj', 'down_proj'],\n",
    "    lora_dropout=0.1,\n",
    "    bias='none',\n",
    "    task_type=TaskType.CAUSAL_LM\n",
    ")\n",
    "\n",
    "model = get_peft_model(model, lora_config)\n",
    "model.print_trainable_parameters()"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Entraînement"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "training_args = TrainingArguments(\n",
    "    output_dir='./medical_model_trained',\n",
    "    num_train_epochs=3,\n",
    "    per_device_train_batch_size=2,\n",
    "    gradient_accumulation_steps=4,\n",
    "    learning_rate=2e-4,\n",
    "    warmup_steps=50,\n",
    "    logging_steps=25,\n",
    "    save_steps=200,\n",
    "    save_total_limit=1,\n",
    "    fp16=True,\n",
    "    remove_unused_columns=False,\n",
    "    report_to='none'\n",
    ")\n",
    "\n",
    "trainer = SFTTrainer(\n",
    "    model=model,\n",
    "    args=training_args,\n",
    "    train_dataset=dataset,\n",
    "    tokenizer=tokenizer,\n",
    "    dataset_text_field='text',\n",
    "    max_seq_length=512,\n",
    ")\n",
    "\n",
    "print('Lancement de l\\'entraînement...')\n",
    "train_result = trainer.train()\n",
    "\n",
    "print('\\n=== METRIQUES D\\'ENTRAINEMENT ===')\n",
    "print(f'Loss finale      : {train_result.training_loss:.4f}')\n",
    "print(f'Epochs           : {training_args.num_train_epochs}')\n",
    "print(f'Exemples         : {len(dataset)}')\n",
    "print(f'Durée totale     : {round(train_result.metrics[\"train_runtime\"] / 60, 1)} minutes')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Test du modèle entraîné"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "def generate_response(prompt, max_tokens=200):\n",
    "    formatted = f'<|user|>\\n{prompt}<|end|>\\n<|assistant|>\\n'\n",
    "    inputs = tokenizer(formatted, return_tensors='pt', truncation=True, max_length=512)\n",
    "    inputs = {k: v.cuda() for k, v in inputs.items()}\n",
    "\n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "        outputs = model.generate(\n",
    "            **inputs,\n",
    "            max_new_tokens=max_tokens,\n",
    "            temperature=0.7,\n",
    "            do_sample=True,\n",
    "            top_p=0.9,\n",
    "            repetition_penalty=1.1,\n",
    "            pad_token_id=tokenizer.eos_token_id\n",
    "        )\n",
    "\n",
    "    new_tokens = outputs[0][inputs['input_ids'].shape[1]:]\n",
    "    response = tokenizer.decode(new_tokens, skip_special_tokens=True).strip()\n",
    "    return response\n",
    "\n",
    "questions = [\n",
    "    'I have a headache and fever for 3 days, what should I do?',\n",
    "    'What are the symptoms of diabetes?',\n",
    "    'I feel very tired all the time, could it be anemia?'\n",
    "]\n",
    "\n",
    "print('=== TEST DU MODELE ===')\n",
    "for q in questions:\n",
    "    print(f'\\nQuestion : {q}')\n",
    "    print(f'Réponse  : {generate_response(q)}')\n",
    "    print('-' * 60)"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Sauvegarde du modèle\n",
    "trainer.save_model('./medical_model_trained')\n",
    "print('Modèle sauvegardé dans ./medical_model_trained')\n",
    "print('\\nPour télécharger : Fichiers (panneau gauche) > medical_model_trained > télécharger')"
   ],
   "execution_count": null,
   "outputs": []
  }
 ]
}"
